<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground"
    tools:context=".ManageBatchesActivity">

    <!-- Background Elements -->
    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/top_right"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/scond_dot_patterns"
        android:alpha="0.5"
        android:rotation="180"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/bottom_left"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/scond_dot_patterns"
        android:alpha="0.5"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">

            <!-- Back Button & Title -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:background="@drawable/bg_circle_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/colorPrimary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Manage Batches"
                android:textColor="@color/textColorPrimary"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivBack" />

            <View
                android:id="@+id/blueLine"
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="@color/colorAccent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvScreenTitle" />

            <TextView
                android:id="@+id/tvScreenSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="View and modify pre-existing batches"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/blueLine" />

            <!-- Select Batch Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSelectBatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/inputBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvScreenSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Batch"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:elevation="1dp">
                        
                        <Spinner
                            android:id="@+id/spinnerBatches"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@null"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <!-- Details Area -->
                    <LinearLayout
                        android:id="@+id/llBatchDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Batch Details"
                            android:textColor="@color/textColorSecondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvSelectedProgramId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Program ID: BIT"
                            android:textColor="@color/textColorPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSelectedBatchId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Batch ID: B01"
                            android:textColor="@color/textColorPrimary"
                            android:textSize="14sp" />
                            
                        <TextView
                            android:id="@+id/tvSelectedBatchName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Name: Intake 1"
                            android:textColor="@color/textColorPrimary"
                            android:textSize="14sp" />
                            
                        <TextView
                            android:id="@+id/tvSelectedIntakeYear"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Intake Year: 2021"
                            android:textColor="@color/textColorPrimary"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Separator / Or text -->
            <TextView
                android:id="@+id/tvOrSeparator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="- OR -"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSelectBatch" />

            <!-- Add New Batch Action -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnToggleAddBatch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_outline_button"
                android:text="+ Add New Batch"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvOrSeparator" />

            <!-- Add New Batch Form (Inline Expansion) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAddBatchForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/inputBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnToggleAddBatch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Batch Details"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Program ID Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_degree"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Program ID"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etProgramId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. BIT"
                                android:inputType="textCapCharacters"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Batch ID Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_semester"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Batch ID"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etBatchId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. B01"
                                android:inputType="textCapCharacters"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Batch Name Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_semester"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Batch Name"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etBatchName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. Intake 1"
                                android:inputType="textCapWords"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Intake Year Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_semester"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Intake Year"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etIntakeYear"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. 2021"
                                android:inputType="number"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Student Details Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Add Student to Batch"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- No Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chats_filled"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No."
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etStudentNo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. 1"
                                android:inputType="number"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Student ID / Index No Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chats_filled"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Student ID or Index No"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etStudentId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. STU001"
                                android:inputType="textCapCharacters"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Full Name Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chats_filled"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full Name"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etStudentFullName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. John Doe"
                                android:inputType="textPersonName"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- University Email Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chats_filled"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="University Email"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etStudentEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. john@uni.edu"
                                android:inputType="textEmailAddress"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Phone Number Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_rounded_input"
                        android:elevation="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chats_filled"
                            app:tint="@color/textColorSecondary" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone Number"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="12sp" />
                            <EditText
                                android:id="@+id/etStudentPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="e.g. +1234567890"
                                android:inputType="phone"
                                android:paddingTop="2dp"
                                android:paddingBottom="0dp"
                                android:textColor="@color/textColorPrimary"
                                android:textColorHint="@color/textColorSecondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Save Action -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSaveBatch"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_gradient_button"
                        android:elevation="4dp"
                        android:text="Save Batch &amp; Student"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Cancel Action -->
                    <TextView
                        android:id="@+id/tvCancelAddBatch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Cancel"
                        android:textColor="@color/textColorSecondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
